# Google Analytics 4 for landing deployment
# Use a separate GA4 property/measurement ID from the main app if needed.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Public landing URL (no trailing slash), used for canonical + OG/Twitter URLs + JSON-LD.
# Example: https://landing.yourdomain.com
VITE_SITE_URL=

# Optional: full share image URL. Defaults to /og-image.png when not set.
# VITE_OG_IMAGE_URL=https://landing.yourdomain.com/og-image.png

# Footer / Apply CTAs: WhatsApp (digits only, country code, no +).
# VITE_WHATSAPP_E164=447947744101
# Telegram: full https URL, or digits only with VITE_TELEGRAM_E164 (07787071561 → 447787071561).
# VITE_TELEGRAM_URL=https://t.me/+447787071561
# VITE_TELEGRAM_E164=447787071561
